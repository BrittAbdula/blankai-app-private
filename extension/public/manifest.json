{
  "manifest_version": 3,
  "name": "BlankAI",
  "version": "1.0.0",
  "description": "Remove image metadata and inspect privacy-related image information locally.",
  "minimum_chrome_version": "116",
  "permissions": ["sidePanel"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open BlankAI"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
